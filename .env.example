# Basic Auth credentials for the password-protected site.
# Copy this file to `.env.local` for local development, and set the same
# variables in Vercel under Project → Settings → Environment Variables.

# Main site login
SITE_USERNAME=admin
SITE_PASSWORD=changeme

# Per-report logins. Each report under /reports/<slug> has its own credentials.
# Add a matching entry in middleware.js when you add a new report.
REPORT_KATHRYN_USER=kathryn
REPORT_KATHRYN_PASS=changeme
REPORT_JOSE_USER=jose
REPORT_JOSE_PASS=changeme
